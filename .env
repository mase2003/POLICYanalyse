# Neo4j 安装目录（例如 D:\neo4j-community-5.17.0）只用于本机启动数据库；
# 本项目的连接地址始终是 Bolt URI，与安装路径无关（默认本机 7687 端口）。
NEO4J_URI=你本机neo4j地址
NEO4J_USER=数据库名
NEO4J_PASSWORD=数据库密码

# 查询超时（秒），防止大查询长时间占用
NEO4J_QUERY_TIMEOUT_SEC=30
NEO4J_PING_TIMEOUT_SEC=5
# 用户 Cypher 最大字符数
NEO4J_MAX_CYPHER_LEN=8000
# 扩展邻居时单次扫描路径条数上限
NEO4J_INTERNAL_SCAN_LIMIT=5000

# 发文机构有两种建模：① 政策节点上的属性 → 只配 CATALOG_ORG_PROP（键名须与 keys(n) 一致）；
# ② 独立标签节点 :发文机构 → 配 CATALOG_ORG_NODE_LABEL，目录从该类节点 DISTINCT，筛选走 (政策)--(机构)。
# Browser 里 MATCH (n:`发文机构`) 表示「发文机构」是标签名，不是属性；此时应走 ②。
CATALOG_ORG_NODE_LABEL=发文机构
CATALOG_ORG_NODE_NAME_PROP=name
# 属性模式用（与 NODE_LABEL 二选一；设了 NODE_LABEL 时目录不再读政策节点上的发文机构属性）
CATALOG_ORG_PROP=发文机构
# ---------- 首页 /api/home（政策节点 schema，按你图里实际标签与属性名改） ----------
HOME_QUERY_TIMEOUT_SEC=8
# 政策节点在 Neo4j 中的「节点标签」，须与 Browser 里看到的 Label 一致（不是文件名属性）。
# 政策目录/顶栏搜索优先读 SEARCH_POLICY_LABEL，未设置时用 HOME_POLICY_LABEL。
HOME_POLICY_LABEL=文件名称
# SEARCH_POLICY_LABEL=
# 目录在带标签 MATCH 无数据时自动改为 MATCH (n)；也可强制：CATALOG_FORCE_UNLABELED_MATCH=true
HOME_TITLE_PROP=name
HOME_CATEGORY_PROP=政策类型
HOME_SEARCH_PROP=searchCount
HOME_DATE_PROP=发文日期
HOME_PIE_SEGMENTS=10
HOME_LIST_LIMIT=5

# 设为 true 且库中存在 :Banner 节点(title,subtitle,theme) 时轮播从库读
# HOME_CAROUSEL_FROM_DB=false

# ---------- 顶栏政策搜索 /api/search/policies（默认与 HOME_POLICY_LABEL、HOME_TITLE_PROP 对齐） ----------
# SEARCH_QUERY_TIMEOUT_SEC=8
# SEARCH_POLICY_LABEL=
# SEARCH_FILE_PROP=文件名称
# SEARCH_ORG_PROP=发文机构
# SEARCH_FILE_ALT_PROP=

# ---------- Redis（爬虫临时缓存） ----------
REDIS_ENABLED=true
REDIS_HOST=Redis本机地址
REDIS_PORT=Redis端口号
REDIS_DB=0
# REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT_SEC=2
REDIS_CACHE_TTL_SEC=900
REDIS_DECODE_RESPONSES=false

# ---------- 政策爬取 ----------
CRAWLER_REQUEST_INTERVAL_SEC=1.5
CRAWLER_REQUEST_TIMEOUT_SEC=10
CRAWLER_RETRY_MAX=2
CRAWLER_CACHE_TTL_SEC=3600

ARK_API_KEY="你的豆包api密匙"
ARK_CHAT_MODEL=豆包模型名称id

# Flask 监听端口与前端请求基址（与 backend/app.py 默认一致）
FLASK_PORT=flask端口号
VITE_API_BASE_URL=flask本机地址